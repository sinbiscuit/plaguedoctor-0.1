PinkyBombExplode {
    template spell
    
    graphics { 
        dont_orient true
        particle Explosion
        animation explode
        delay 1
    }
    
    cost {
        mana 5
    }
    
    target {
        aoe_mode pierce_cross
        knockback_mode character_to_tile
        
        target_mode none
        min_range 0
        max_range 0
        
        min_aoe 1
        max_aoe 1
    }
    
    damage_instance {
        damage 5
        elements [
            Fire
            Explosion
        ]
        ai_base_score 9999
    }
}

