            Burn [1 .1]
            Bleed [1 .1]
            Weakness [1 .1]
            Slow [1 .1]
            Rot [1 .1]
            Poison [1 .1]
            Burn [1 .1]
            Bleed [1 .1]
            Weakness [1 .1]
            Slow [1 .1]
            Rot [1 .1]

            ApplyToSource {
                PartialCleanse 2
            } 
        }
    }
}

