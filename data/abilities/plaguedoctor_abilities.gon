PlaguedoctorInfect = {
    template spell

    meta {
        name "Infect"
        desc "Deal low damage while inflicting Poison 1 to a unit."
        animate_name false
        class Plaguedoctor
    }

    graphics {
        particle PoisonPoof
        animation evilMagic
    }
    
    cost {
        move_points 0
        act_points 1
    }
    
    target {
        max_aoe 0
        max_range 5
    }
    
    damage_instance {
        damage 1+bonus_basic_spell_damage

        effects {
            Poison 1
        }
    }
},

PlaguedoctorInfectBasic {
    variant_of PlaguedoctorInfect
    meta {
        ability_icon Pestilence
        class Plaguedoctor
    }
}

