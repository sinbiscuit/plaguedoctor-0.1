Myasis {
    template spell
	
    graphics {
        particle PoisonPoof
		animation evilMagic
    }

    
    meta {
        name "Myasis"
        desc "Destroy a body and spawn a Carcass. This can also mutate certain units."
        class Plaguedoctor
        type_icon "spawn"
    }

    tags [summon]

    cost {
        infcantrip true
        mana 5
    }

    target {
        max_aoe 0
        min_range 1
        max_range 5+bonus_range
    }

    damage_instance {
        damage 0

        effects {
            Conditional_DestructibleCorpse {
                VaporizeCorpse 1
                    ObjectOnHitCharacter CharmedCarcus
            }
        }

        elements [
            Mutate
        ]
    }
}

