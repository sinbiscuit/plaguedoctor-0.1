Transmit {
    template melee_attack

    meta {
        name "Transmit"
        desc "Touch another unit to cleanse 1 stack of a random debuff and inflict 1-2 random debuffs."
        class Plaguedoctor
    }

    graphics {
    }

    cost {
        infcantrip true
        mana 3
    }

    
    damage_instance {
        damage 0

        effects {
            RandomStatusFromPool {
                Poison 1
                Burn 1
                Bleed 1
                Weakness 1
                Slow 1
                Rot 1
            }
            Poison [1 .1]
            Burn [1 .1]
            Bleed [1 .1]
            Weakness [1 .1]
            Slow [1 .1]
            Rot [1 .1]

            ApplyToSource {
                PartialCleanse 1
            }
        }
    }
}

Transmit2 {
    variant_of Transmit

    meta {
        desc "Touch another unit to cleanse 2 stacks of a random debuff and inflict 2-4 random debuffs."
    }

    damage_instance {

