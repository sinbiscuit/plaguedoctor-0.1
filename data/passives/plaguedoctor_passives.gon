STARTER_PLACEHOLDER_Plaguedoctor {
    icon STARTER_PLACEHOLDER_Fighter
    name "PASSIVE_STARTER_PLACEHOLDER_NAME"
    desc "o,_ o"
    class Plaguedoctor
}

SuperRat = {
    name = "Super Rat!"
    desc = "Your plague rat has its abilities upgraded."
    class = Plaguedoctor
    1 {
        passives {
            ReplaceSpawnedObjects ["PlagueRat2", "PlagueRat3"]
            ReplaceSpawnedObjects ["PlagueRat", "PlagueRat2"]
        }
    }   
    

    2 {
        desc "Your plague rat has its abilities upgraded... Twice!"
        passives {
            ReplaceSpawnedObjects ["PlagueRat2", "PlagueRat3"]
            ReplaceSpawnedObjects ["PlagueRat", "PlagueRat3"]
        }
    }   
}

ROUS = {
    name = "R.O.U.S."
    desc = "Your plague rat is bigger!"
    class = Plaguedoctor
    1 {
        passives {            
